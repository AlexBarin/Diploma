      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "adaptive_engine_compute_duration_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "adaptive_engine_compute_duration_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95",
          "refId": "B"
