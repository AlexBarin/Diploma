        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "sum by(datname) (pg_stat_activity_count{job=\"postgres\",state=\"active\",datname=\"metriclab\"})", "legendFormat": "actual", "interval": "15s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_baseline_value{metric_alias=\"postgres_active_connections\"})", "legendFormat": "baseline", "interval": "15s" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_lower_band{metric_alias=\"postgres_active_connections\"})", "legendFormat": "lower", "interval": "15s" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_upper_band{metric_alias=\"postgres_active_connections\"})", "legendFormat": "upper", "interval": "15s" },
        { "refId": "E", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_forecast_value{metric_alias=\"postgres_active_connections\"} and on (app,analysis_mode,fallback_used,metric_alias,model_name,series_id,source_container,source_drive,source_endpoint,source_host,source_instance,source_job,source_job_type,source_service,horizon_step) (abs(predictive_forecast_timestamp_seconds{metric_alias=\"postgres_active_connections\"} - time()) < 15))", "legendFormat": "forecast", "interval": "15s" },
        { "refId": "F", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_forecast_lower_band{metric_alias=\"postgres_active_connections\"} and on (app,analysis_mode,fallback_used,metric_alias,model_name,series_id,source_container,source_drive,source_endpoint,source_host,source_instance,source_job,source_job_type,source_service,horizon_step) (abs(predictive_forecast_timestamp_seconds{metric_alias=\"postgres_active_connections\"} - time()) < 15))", "legendFormat": "f.lower", "interval": "15s" },
