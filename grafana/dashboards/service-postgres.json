          { "matcher": { "id": "byRegexp", "options": "^(lower|upper)$" }, "properties": [{ "id": "custom.lineWidth", "value": 1 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } }] },
