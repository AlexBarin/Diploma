  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" },
        "definition": "label_values(lab_http_request_duration_seconds_bucket{job=\"metric-lab-app\"}, endpoint)",
        "query": { "query": "label_values(lab_http_request_duration_seconds_bucket{job=\"metric-lab-app\"}, endpoint)", "refId": "endpoint" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": "",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "title": "API Latency p95 — $endpoint",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "repeat": "endpoint",
      "repeatDirection": "h",
      "maxPerRow": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 0, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "insertNulls": false, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "auto", "spanNulls": true, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
          "unit": "ms"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "actual" }, "properties": [{ "id": "custom.lineWidth", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "baseline" }, "properties": [{ "id": "custom.lineWidth", "value": 2 }] },
          { "matcher": { "id": "byRegexp", "options": "^(lower|upper)$" }, "properties": [{ "id": "custom.lineWidth", "value": 1 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } }] },
          { "matcher": { "id": "byName", "options": "forecast" }, "properties": [{ "id": "custom.lineWidth", "value": 2 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 6] } }, { "id": "custom.showPoints", "value": "never" }, { "id": "custom.spanNulls", "value": false }] },
          { "matcher": { "id": "byRegexp", "options": "^f\\.(lower|upper)$" }, "properties": [{ "id": "custom.lineWidth", "value": 1 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [3, 5] } }, { "id": "custom.showPoints", "value": "never" }, { "id": "custom.spanNulls", "value": false }] }
        ]
      },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "histogram_quantile(0.95, sum by(le) (rate(lab_http_request_duration_seconds_bucket{job=\"metric-lab-app\",endpoint=\"$endpoint\"}[3m]))) * 1000", "legendFormat": "actual", "interval": "15s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_baseline_value{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"})", "legendFormat": "baseline", "interval": "15s" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_lower_band{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"})", "legendFormat": "lower", "interval": "15s" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_upper_band{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"})", "legendFormat": "upper", "interval": "15s" },
        { "refId": "E", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_forecast_value{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"} and on (app,analysis_mode,fallback_used,metric_alias,model_name,series_id,source_container,source_drive,source_endpoint,source_host,source_instance,source_job,source_job_type,source_service,horizon_step) (abs(predictive_forecast_timestamp_seconds{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"} - time()) < 15))", "legendFormat": "forecast", "interval": "15s" },
        { "refId": "F", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_forecast_lower_band{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"} and on (app,analysis_mode,fallback_used,metric_alias,model_name,series_id,source_container,source_drive,source_endpoint,source_host,source_instance,source_job,source_job_type,source_service,horizon_step) (abs(predictive_forecast_timestamp_seconds{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"} - time()) < 15))", "legendFormat": "f.lower", "interval": "15s" },
        { "refId": "G", "datasource": { "type": "prometheus", "uid": "prometheus-metric-lab" }, "expr": "max by (series_id) (predictive_forecast_upper_band{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"} and on (app,analysis_mode,fallback_used,metric_alias,model_name,series_id,source_container,source_drive,source_endpoint,source_host,source_instance,source_job,source_job_type,source_service,horizon_step) (abs(predictive_forecast_timestamp_seconds{metric_alias=\"api_latency_p95_ms\",source_endpoint=\"$endpoint\"} - time()) < 15))", "legendFormat": "f.upper", "interval": "15s" }
      ]
    },
