        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [
    { "title": "App", "type": "link", "url": "/d/service-metric-lab-app/service-metric-lab-app", "keepTime": true },
    { "title": "Worker", "type": "link", "url": "/d/service-metric-lab-worker/service-metric-lab-worker", "keepTime": true },
    { "title": "Predictive", "type": "link", "url": "/d/service-predictive-module/service-predictive-module", "keepTime": true },
    { "title": "Postgres", "type": "link", "url": "/d/service-postgres/service-postgres", "keepTime": true },
    { "title": "Redis", "type": "link", "url": "/d/service-redis/service-redis", "keepTime": true },
